{
	"name": "@shikytemo/shitools",
	"version": "1.3.0",
	"description": "Reusable scraping tools collection.",
	"main": "src/index.js",
	"types": "types/index.d.ts",
	"bin": {
		"shitools-catbox": "examples/catbox.js",
		"shitools-pinterest": "examples/pinterest.js",
		"shitools-scrapers": "examples/scrapers.js",
		"shitools-sources": "examples/sources.js"
	},
	"type": "module",
	"files": [
		"src",
		"examples",
		"types",
		"README.md"
	],
	"scripts": {
		"start": "node src/index.js",
		"example": "node examples/basic-fetch.js",
		"catbox": "node examples/catbox.js",
		"check": "node --check src/index.js && node --check src/anime.js && node --check src/catbox.js && node --check src/converter.js && node --check src/errors.js && node --check src/http.js && node --check src/indo.js && node --check src/pinterest.js && node --check src/registry.js && node --check src/samehadaku.js && node --check src/source-profiles.js && node --check src/sources.js && node --check src/utility.js && node --check src/web.js && node --check examples/basic-fetch.js && node --check examples/catbox.js && node --check examples/pinterest.js && node --check examples/scrapers.js && node --check examples/sources.js",
		"lint": "eslint .",
		"format": "prettier --write \"**/*.{js,json,md,yml,yaml}\"",
		"format:check": "prettier --check \"**/*.{js,json,md,yml,yaml}\"",
		"test": "vitest",
		"test:run": "vitest run",
		"build:types": "tsc -p tsconfig.json",
		"prepare": "husky || true"
	},
	"keywords": [
		"scraper",
		"tools",
		"automation"
	],
	"author": "Shikytemo",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Shikytemo/shitools.git"
	},
	"bugs": {
		"url": "https://github.com/Shikytemo/shitools/issues"
	},
	"homepage": "https://github.com/Shikytemo/shitools#readme",
	"dependencies": {
		"axios": "^1.15.2",
		"cheerio": "^1.2.0",
		"fluent-ffmpeg": "^2.1.3"
	},
	"devDependencies": {
		"@eslint/js": "^9.13.0",
		"@vitest/coverage-v8": "^2.1.4",
		"eslint": "^9.13.0",
		"globals": "^15.11.0",
		"husky": "^9.1.6",
		"lint-staged": "^15.2.10",
		"prettier": "^3.3.3",
		"typescript": "^5.6.3",
		"vitest": "^2.1.4"
	},
	"lint-staged": {
		"*.{js,json,md,yml,yaml}": [
			"prettier --write"
		],
		"*.js": [
			"eslint --fix"
		]
	},
	"engines": {
		"node": ">=20"
	}
}

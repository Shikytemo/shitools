# ────────────────────────────────────────────────────────────────────
# shitools — runtime environment defaults
# Copy to .env and uncomment the values you want to override.
# ────────────────────────────────────────────────────────────────────

# HTTP defaults (consumed by src/http.js + src/index.js#fetchText)
USER_AGENT=Shitools/1.0
REQUEST_TIMEOUT_MS=30000

# Optional outbound proxy (HTTP / HTTPS). Leave empty to bypass.
# SHITOOLS_PROXY=http://user:pass@proxy.example.com:8080

# Optional Catbox account user hash. Anonymous uploads work without this.
CATBOX_USER_HASH=

# REST server example (examples/server.js)
PORT=3000
